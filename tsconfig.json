{
  "compilerOptions": {
    "inlineSourceMap": true,
    "module": "ESNext",
    "target": "ESNext",
    "allowJs": true,
    "noImplicitAny": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "isolatedModules": true,
    "strictNullChecks": true,
    "skipLibCheck": true,
    "types": [
      "node"
    ],
    "lib": [
      "DOM",
      "ESNext"
    ],
    "paths": {
      "@/*": [
        "./src/*"
      ]
    }
  },
  "include": [
    "**/*.ts"
  ],
  "exclude": [
    "**/*.test.ts",
    "node_modules"
  ]
}
