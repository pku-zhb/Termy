{
  "name": "termy",
  "version": "1.3.7",
  "type": "module",
  "description": "Terminal emulator with split panes, reusable workflows, AI CLI context handoff, and zero setup. Powered by xterm.js and a bundled Rust PTY backend.",
  "main": "main.js",
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "lint": "eslint \"src/**/*.ts\"",
    "lint:obsidian": "eslint -c eslint.obsidian.config.js \"src/**/*.ts\"",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production && node scripts/verify-build.js",
    "build:rust": "node scripts/build-rust.js",
    "build:rust:clean": "node scripts/build-rust.js --clean",
    "package": "node scripts/package-plugin.js",
    "package:zip": "node scripts/package-plugin.js --zip",
    "repro:scrollback": "node scripts/repro-scrollback.js",
    "repro:scrollback:ed2": "node scripts/repro-scrollback.js --mode ed2",
    "repro:scrollback:ed3": "node scripts/repro-scrollback.js --mode ed3",
    "repro:scrollback:sync-ed2": "node scripts/repro-scrollback.js --mode sync-ed2",
    "repro:scrollback:sync-ed3": "node scripts/repro-scrollback.js --mode sync-ed3",
    "test:scripts": "node --test scripts/*.test.js",
    "upload:r2": "node scripts/upload-r2-assets.js --bucket termy-binaries-apac",
    "test:terminal": "tsc -p tsconfig.test.json --pretty false && node --experimental-strip-types --experimental-specifier-resolution=node --test src/services/terminal/*.test.ts",
    "verify:bundle": "node scripts/verify-build.js",
    "release": "pnpm build && pnpm build:rust && pnpm package:zip",
    "install:dev": "pnpm build && pnpm build:rust && node scripts/install-dev.js"
  },
  "keywords": [
    "obsidian",
    "plugin",
    "terminal",
    "xterm",
    "pty"
  ],
  "author": "ZyphrZero",
  "license": "GPL-3.0",
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/node": "^20.12.12",
    "builtin-modules": "^5.0.0",
    "esbuild": "^0.27.2",
    "esbuild-compress": "^2.0.2",
    "eslint": "^9.39.2",
    "eslint-plugin-obsidianmd": "0.2.4",
    "globals": "^17.0.0",
    "obsidian": "^1.11.0",
    "tslib": "2.8.1",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.51.0",
    "ws": "^8.18.3"
  },
  "dependencies": {
    "@xterm/addon-canvas": "^0.7.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "simple-icons": "^15.13.0"
  }
}
